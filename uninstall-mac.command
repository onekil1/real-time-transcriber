#!/usr/bin/env bash
# ==========================================================
#  Транскрибатор - ПОЛНОЕ удаление установки на macOS.
#  Стирает всё в папке проекта (модели, БД, venv, .git, код)
#  и оставляет только этот файл - чтобы можно было сразу
#  поставить заново через git clone + install-mac.sh.
#  Модель Whisper при следующем install подтянется автоматом.
#  Файл должен лежать В КОРНЕ проекта и запускаться оттуда
#  (двойной клик в Finder или `bash uninstall-mac.command`).
# ==========================================================

set -u
cd "$(dirname "$0")"
SELF="$(basename "$0")"

cat <<EOF
==========================================================
 ВНИМАНИЕ: будет удалено ВСЁ в папке
   $(pwd -P)
 включая:
   - models/ (веса Whisper, ~1.5-3 ГБ — придётся качать заново)
   - data/   (БД с сессиями и аудио)
   - .venv/  (venv с зависимостями)
   - app/, web/, scripts/, .git/ и пр.
 Останется только $SELF (этот файл).
==========================================================
EOF

read -r -p "Введите YES (заглавными) для продолжения: " CONFIRM
if [ "${CONFIRM:-}" != "YES" ]; then
  echo "Отменено."
  read -r -p "Enter для выхода..." _
  exit 1
fi

echo
echo "Удаляю содержимое..."
# Удаляем всё в текущей папке кроме самого скрипта.
# find -mindepth 1 — не трогает саму папку.
find . -mindepth 1 -maxdepth 1 ! -name "$SELF" -exec rm -rf {} + 2>/dev/null

# Заодно подчищаем ярлык на рабочем столе, если был.
SHORTCUT="$HOME/Desktop/Транскрибатор.command"
if [ -f "$SHORTCUT" ]; then
  rm -f "$SHORTCUT"
  echo "Удалён ярлык: $SHORTCUT"
fi

echo
cat <<EOF
==========================================================
 Готово. В папке остался только $SELF.
==========================================================
 Дальше (по одной строке в Терминале, в этой же папке):

   git clone https://github.com/onekil1/real-time-transcriber.git tmp
   mv tmp/* tmp/.[!.]* . 2>/dev/null
   rmdir tmp
   bash scripts/install-mac.sh

 При первом запуске программа сама скачает модель Whisper
 с HuggingFace прямо в models/whisper/mac/ — никаких ручных
 шагов с моделью не нужно.
==========================================================
EOF
read -r -p "Enter для выхода..." _
